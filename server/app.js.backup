const express = require('express');
const cors = require('cors');
const fs = require('fs');
const path = require('path');
const { v4: uuidv4 } = require('uuid');

const app = express();
const PORT = process.env.PORT || 5000;

// Middleware
app.use(cors());
app.use(express.json());

// Serve static files from client build
app.use(express.static(path.join(__dirname, '..', 'client', 'dist')));

// Database file path
const DATA_DIR = path.join(__dirname, '..', 'data');
const DB_FILE = path.join(DATA_DIR, 'db.json');

// Ensure data directory exists
if (!fs.existsSync(DATA_DIR)) {
  fs.mkdirSync(DATA_DIR, { recursive: true });
}

// Initialize database if not exists
function initDatabase() {
  if (!fs.existsSync(DB_FILE)) {
    const initialData = {
      profile: {
        name: 'Samrawit Yirga (Sam)',
        title: 'Computer Science Student',
        bio: 'Passionate full-stack developer with a focus on creating beautiful and functional web applications. Always eager to learn new technologies and take on challenging projects.',
        image: null,
        email: 'sam@example.com',
        location: 'Ethiopia',
        socialLinks: {
          github: '',
          linkedin: '',
          twitter: ''
        }
      },
      projects: [],
      skills: [],
      experience: [],
      messages: []
    };
    fs.writeFileSync(DB_FILE, JSON.stringify(initialData, null, 2));
  }
}

// Read database
function readDatabase() {
  initDatabase();
  const data = fs.readFileSync(DB_FILE, 'utf8');
  return JSON.parse(data);
}

// Write database
function writeDatabase(data) {
  fs.writeFileSync(DB_FILE, JSON.stringify(data, null, 2));
}

// ============ PROFILE ROUTES ============

// GET /profile - Get profile info
app.get('/api/profile', (req, res) => {
  try {
    const db = readDatabase();
    res.json(db.profile);
  } catch (error) {
    res.status(500).json({ error: 'Failed to read profile' });
  }
});

// PUT /profile - Update profile
app.put('/api/profile', (req, res) => {
  try {
    const db = readDatabase();
    db.profile = { ...db.profile, ...req.body };
    writeDatabase(db);
    res.json(db.profile);
  } catch (error) {
    res.status(500).json({ error: 'Failed to update profile' });
  }
});

// ============ PROJECTS ROUTES ============

// GET /projects - Get all projects
app.get('/api/projects', (req, res) => {
  try {
    const db = readDatabase();
    res.json(db.projects);
  } catch (error) {
    res.status(500).json({ error: 'Failed to read projects' });
  }
});

// GET /projects/:id - Get single project
app.get('/api/projects/:id', (req, res) => {
  try {
    const db = readDatabase();
    const project = db.projects.find(p => p.id === req.params.id);
    if (!project) {
      return res.status(404).json({ error: 'Project not found' });
    }
    res.json(project);
  } catch (error) {
    res.status(500).json({ error: 'Failed to read project' });
  }
});

// POST /projects - Add new project
app.post('/api/projects', (req, res) => {
  try {
    const db = readDatabase();
    const newProject = {
      id: uuidv4(),
      ...req.body,
      createdAt: new Date().toISOString()
    };
    db.projects.push(newProject);
    writeDatabase(db);
    res.status(201).json(newProject);
  } catch (error) {
    res.status(500).json({ error: 'Failed to create project' });
  }
});

// PUT /projects/:id - Update project
app.put('/api/projects/:id', (req, res) => {
  try {
    const db = readDatabase();
    const index = db.projects.findIndex(p => p.id === req.params.id);
    if (index === -1) {
      return res.status(404).json({ error: 'Project not found' });
    }
    db.projects[index] = { ...db.projects[index], ...req.body };
    writeDatabase(db);
    res.json(db.projects[index]);
  } catch (error) {
    res.status(500).json({ error: 'Failed to update project' });
  }
});

// DELETE /projects/:id - Delete project
app.delete('/api/projects/:id', (req, res) => {
  try {
    const db = readDatabase();
    const index = db.projects.findIndex(p => p.id === req.params.id);
    if (index === -1) {
      return res.status(404).json({ error: 'Project not found' });
    }
    db.projects.splice(index, 1);
    writeDatabase(db);
    res.json({ message: 'Project deleted successfully' });
  } catch (error) {
    res.status(500).json({ error: 'Failed to delete project' });
  }
});

// ============ SKILLS ROUTES ============

